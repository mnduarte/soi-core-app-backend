# SOI backend — environment variables
# Copy to `.env` for local dev. In production these are set on Fly with
# `fly secrets set KEY=value` instead of being committed.

# ---- Runtime ----
NODE_ENV=development
PORT=3000

# ---- MongoDB ----
# Local: mongodb://127.0.0.1:27017/soi
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/soi?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/soi

# ---- JWT ----
# Generate strong random values for production, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_USER_SECRET=change_me_dev_secret
JWT_USER_EXPIRES_IN=15m
JWT_USER_REFRESH_EXPIRES_IN=1d

JWT_ADMIN_SECRET=change_me_dev_secret
JWT_ADMIN_EXPIRES_IN=24h

# ---- Cloudinary (gallery photo storage) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- CORS ----
# Comma-separated list of allowed frontend origins for production. Localhost
# is always allowed, so this is just for the deployed Vercel apps.
# Example: https://app.soi.com.ar,https://console.soi.com.ar
FRONTEND_URLS=

# ---- Invitations ----
INVITATION_TOKEN_EXPIRES_DAYS=7

# ---- Throttling ----
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ---- Telegram bot (super-admin alerts) ----
# Optional. Without these, alerts are logged but not pushed.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
